    "**/Thumbs.db": true,
    "node_modules": true,
    ".next": true,
    ".contentlayer": true,
    ".yarn": true,
    ".husky": true,
    ".github": true,
    ".devcontainer": true,
    ".vscode": false,
    ".gitattributes": true,
    ".gitignore": true,
    ".yarnrc.yml": true,
    ".env.example": true,
    "yarn.lock": true,
    "package-lock.json": true,
